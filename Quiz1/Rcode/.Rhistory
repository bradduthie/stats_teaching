CO2   <- dat$Dissolved_CO2
ctst  <- suppressWarnings(cor.test(O2, CO2, method = "spearman"));
ans   <- as.numeric(ctst$estimate);
return(ans);
}
Q23_ans <- function(dat){
mod   <- lm(Turbidity ~ Fish_density, data = dat);
res   <- residuals(mod);
max   <- max(abs(res));
lake  <- as.numeric(which(abs(res) == max));
ans   <- lake
return(ans);
}
Q24_ans <- function(dat){
N     <- dim(dat)[1];
dd    <- N - 2;
ans   <- qt(p = 0.975, df = dd);
return(ans);
}
Q25_ans <- function(dat){
mod   <- lm(Silica ~ Depth + I(Depth^2), data = dat);
smm   <- summary(mod);
ans   <- smm[["adj.r.squared"]];
return(ans);
}
Q25_alt <- function(dat){
mod   <- lm(Silica ~ Depth + I(Depth^2), data = dat);
smm   <- summary(mod);
ans   <- smm[["adj.r.squared"]] * 100;
return(ans);
}
