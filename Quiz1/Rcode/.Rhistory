library(emayili);
library(magrittr);
st <- read.csv("class_FRI.csv"); # CSV file with names and email addresses
smtp <- server(host = "smarthost.stir.ac.uk")
for(i in 1:nrow(st)) {
st_name  <- st[i, 7];  # Table column 1 has the name
st_ID    <- st[i, 1];  # Table column 2 has student ID
st_extra <- st[i, 10]; # Table column 3 has some other information
st_email <- st[i, 3];  # Table column 4 has the email address
file1 <- paste0("data/pesticides/pesticides_", st_ID, ".csv");
file2 <- paste0("data/tomatoes/tomatoes_", st_ID, ".csv");
extra_sentence <- ""
if(st_extra == 0) {
extra_sentence <- "<p>You will have four hours to complete the exam
(09:00-13:00).</p>"
}
if(st_extra == 25) {
extra_sentence <- "<p>You will have five hours to complete the
exam (09:00-14:00).</p>"
} else if(st_extra == 50) {
extra_sentence <- "<p>You will have six hours to complete the exam
(09:00-15:00).</p>"
}
# Build HTML body
body_html <- sprintf("
<p>Hi %s,</p>
<p>I hope that you are doing well! Please find attached the datasets that you
need to complete the exam. </p>
<p>I recommend that you save these files, then open it them in jamovi. Please use
these datasets to complete the questions as necessary. Note that these files
might not be in a tidy format.</p>
<p>Remember that the test is open book and open note, but you must complete
the test independently and not consult with anyone else to answer the
questions.</p>
%s
<p>I will be available by email and MS Teams if you need me during the
test</p>
<p>Cheers,<br><br>
Brad</p>
<p>
#=====================<br>
A. Bradley Duthie (he/him), PhD, FHEA<br>
Lecturer in Environmental Modelling<br>
Biological and Environmental Sciences<br>
University of Stirling <br>
<a href='http://bradduthie.github.io'>http://bradduthie.github.io/</a><br>
<a href='https://outlook.office.com/bookwithme/user/4d0e07e786154c059fdee9af6579e88f@stir.ac.uk/meetingtype/1VIE13Eo40umw-fitsib7w2?anonymous&ismsaljsauthenabled&ep=mLinkFromTile'>Book a meeting with me</a>
</p>
", st_name, extra_sentence)
email <- envelope() %>%
from("Brad Duthie <alexander.duthie@stir.ac.uk>") %>%
to(c(st_email, "Brad Duthie <alexander.duthie@stir.ac.uk>")) %>%
subject("SCIU4T4: Datasets for Exam") %>%
html(body_html)          # <-- use html() instead of text()
if(file.exists(file1)) email <- attachment(email, file1, name = basename(file1))
if(file.exists(file2)) email <- attachment(email, file2, name = basename(file2))
smtp(email, verbose = TRUE);
Sys.sleep(2); # This pauses before sending the next email in the loop (2 s)
}
